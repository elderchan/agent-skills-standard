{
  "name": "agent-skills-standard-mcp",
  "version": "0.2.0",
  "description": "MCP server that lets any AI agent (Claude, Cursor, Antigravity, Kiro, Continue, Gemini) load and audit skills from agent-skills-standard.",
  "main": "dist/index.js",
  "bin": {
    "agent-skills-standard-mcp": "dist/index.js",
    "ags-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --target node20 --shims --clean",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "lint:check": "eslint \"src/**/*.ts\""
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "agent",
    "skills",
    "claude",
    "cursor",
    "antigravity",
    "kiro",
    "continue",
    "gemini"
  ],
  "author": "Hoang Nguyen",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "fs-extra": "^11.2.0",
    "js-yaml": "^4.1.0",
    "minimatch": "^10.0.1",
    "express": "^4.19.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.30",
    "@vitest/coverage-v8": "^4.0.17",
    "tsup": "^8.3.5",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}
