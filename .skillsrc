registry: https://github.com/HoangNguyen0403/agent-skills-standard
agents:
  - copilot
  - antigravity
skills:
  typescript:
    ref: typescript-v1.3.0
  common:
    ref: common-v1.9.0
    exclude:
      - accessibility
      - api-design
      - architecture-audit
      - architecture-diagramming
      - error-handling
      - mobile-animation
      - mobile-ux-core
      - observability
custom_overrides: []
workflows:
  - code-review
  - codebase-review
  - plan-feature
  - skill-benchmark
