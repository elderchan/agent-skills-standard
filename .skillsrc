registry: https://github.com/HoangNguyen0403/agent-skills-standard
agents:
  - copilot
  - antigravity
  - openai
skills:
  typescript:
    ref: typescript-v1.3.3
  common:
    ref: common-v2.0.5
    exclude:
      - common-accessibility
      - common-api-design
      - common-architecture-audit
      - common-architecture-diagramming
      - common-error-handling
      - common-mobile-animation
      - common-mobile-ux-core
      - common-observability
custom_overrides: []
workflows:
  - code-review
  - codebase-review
  - plan-feature
  - skill-benchmark
  - pentest
  - dev-fix
  - implement-feature
  - verify-bug
mcp:
  enabled: true
  scope: project
  prompted: true
